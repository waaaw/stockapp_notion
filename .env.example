# Notion Integration 토큰 (https://notion.so/my-integrations 에서 발급)
NOTION_TOKEN=secret_xxx

# 4개 데이터베이스 ID (scripts/setup_notion_databases.py 실행 후 출력되는 값을 채워 넣거나,
# Notion에서 DB를 직접 만든 뒤 URL에서 추출한 32자리 ID를 채워 넣는다)
DB_STOCKS_ID=
DB_TRANSACTIONS_ID=
DB_PORTFOLIO_ID=
DB_DIVIDENDS_ID=

# 로그 레벨: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# 웹 UI 세션 키. 로컬 무인증 사용이면 비워둬도 되지만, 아래 로그인(WEB_USERNAME/WEB_PASSWORD)을
# 켜면 반드시 채워야 한다(멀티 워커 환경에서 세션이 깨지는 것을 방지). 예: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# --- 웹 UI 호스트/포트/로그인 ---
# 로컬 전용(기본값): 127.0.0.1. Docker/외부 접속용으로는 0.0.0.0 (실제 노출 범위는
# 포트 매핑/Tailscale이 결정하므로 0.0.0.0 자체가 인터넷에 바로 노출되는 것은 아니다)
WEB_HOST=127.0.0.1
WEB_PORT=5000
# 둘 다 채우면 로그인 화면이 뜬다. 비워두면(기본값) 로컬 전용처럼 인증 없이 동작.
# 외부에서 접속할 계획이면 반드시 채울 것.
WEB_USERNAME=
WEB_PASSWORD=

# --- 한국투자증권(KIS) Open API (선택 기능) ---
# https://apiportal.koreainvestment.com/apiservice 에서 API 신청 후 발급받은 값
# KIS_APP_KEY를 비워두면 KIS 관련 기능은 전부 비활성화된다
KIS_APP_KEY=
KIS_APP_SECRET=
# 계좌번호 10자리: 종합계좌 8자리 + 상품코드 2자리 (하이픈 있어도 무방)
KIS_ACCOUNT_NO=
# true=모의투자(기본값, 안전), false=실계좌 - 모의투자로 충분히 검증한 뒤에만 false로 변경할 것
KIS_IS_PAPER=true
